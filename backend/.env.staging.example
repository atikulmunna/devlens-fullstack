APP_NAME=DevLens Backend
ENV=staging
DATABASE_URL=postgresql+psycopg://postgres:<password>@<supabase-host>:5432/postgres
REDIS_URL=rediss://default:<password>@<upstash-host>:6379
QDRANT_URL=https://<qdrant-cloud-host>:6333
QDRANT_COLLECTION=devlens_code_chunks
QDRANT_API_KEY=replace-me
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
GITHUB_OAUTH_REDIRECT_URI=https://<staging-backend-domain>/api/v1/auth/callback
FRONTEND_URL=https://<staging-frontend-domain>
OPENROUTER_API_KEY=replace-me
GROQ_API_KEY=replace-me
LLM_CHAT_MODEL=openai/gpt-4o-mini
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_PRIMARY_PROVIDER=openrouter
LLM_FALLBACK_PROVIDER=groq
LLM_PRIMARY_TIMEOUT_SECONDS=15
LLM_FALLBACK_TIMEOUT_SECONDS=15
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_BASE_URL=https://api.groq.com/openai/v1
JWT_SECRET=replace-me
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_DAYS=7
SHARE_TOKEN_TTL_DAYS=7
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_GUEST_PER_WINDOW=10
RATE_LIMIT_AUTH_PER_WINDOW=50
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_CANDIDATE_LIMIT=50
R2_BUCKET=replace-me
R2_ACCESS_KEY=replace-me
R2_SECRET_KEY=replace-me
