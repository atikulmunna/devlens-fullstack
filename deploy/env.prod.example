# DevLens production env (single-box). Copy to .env.prod on the host and fill in.
# Loaded by docker-compose.prod.yml for both interpolation and container env.

# --- App ---
APP_NAME=DevLens
ENV=production

# --- Public domain + TLS (Caddy) ---
# Free option: sslip.io encodes the instance IP as the hostname (no signup, no DNS record).
# After provisioning, set this to <elastic-ip-with-dashes>.sslip.io, e.g. 52-1-2-3.sslip.io
# (Fallback if Let's Encrypt rate-limits sslip.io: a free DuckDNS subdomain.)
DEVLENS_DOMAIN=CHANGE-ME.sslip.io
DEVLENS_TLS_EMAIL=you@example.com
# Shared access key for the private-alpha gate (the branded login page). Hand this to
# people you invite. Rotate it to revoke access for everyone.
DEVLENS_GATE_SECRET=change-me-to-a-strong-access-key

# --- Datastores (internal to the compose network) ---
POSTGRES_DB=devlens
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql+psycopg://postgres:change-me-strong@postgres:5432/devlens
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=devlens_code_chunks

# --- Embeddings (NVIDIA NIM) ---
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=nvapi-xxxxxxxx
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_VECTOR_SIZE=1024

# --- Chat (Nemotron via NIM, Groq fallback) ---
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
GROQ_API_KEY=gsk_xxxxxxxx
LLM_PRIMARY_PROVIDER=nemotron
LLM_FALLBACK_PROVIDER=groq
# OpenRouter is unused by default; a placeholder is fine (backend requires the var).
OPENROUTER_API_KEY=unused

# Reranker is forced off in compose (RERANKER_ENABLED=false) to keep the box light.

# --- Auth ---
GITHUB_CLIENT_ID=your-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-oauth-app-client-secret
# Must match the OAuth app callback and the public domain (the sslip.io hostname above).
GITHUB_OAUTH_REDIRECT_URI=https://CHANGE-ME.sslip.io/api/v1/auth/callback
FRONTEND_URL=https://CHANGE-ME.sslip.io
JWT_SECRET=generate-a-long-random-string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
SHARE_TOKEN_TTL_DAYS=7

# --- Share export storage (required to boot; dummy values are fine if unused) ---
R2_BUCKET=unused
R2_ACCESS_KEY=unused
R2_SECRET_KEY=unused

# --- Worker tuning (optional; defaults apply if omitted) ---
EMBED_BATCH_SIZE=32
EMBED_CACHE_TTL_SECONDS=604800
# Worker analysis summary uses Groq (the worker's summary path supports openrouter/groq).
LLM_SUMMARY_PROVIDER=groq
LLM_SUMMARY_MODEL=llama-3.1-8b-instant
