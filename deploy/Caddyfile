# DevLens private-alpha reverse proxy.
#
# DEVLENS_DOMAIN / DEVLENS_TLS_EMAIL / DEVLENS_GATE_SECRET are injected from .env.prod
# via docker-compose. Caddy fetches a real Let's Encrypt certificate automatically for a
# public domain (a free sslip.io hostname derived from the Elastic IP).
#
# Gating: visitors without a valid access cookie see a branded login page (gate.html).
# Submitting the correct access key sets an httpOnly cookie, after which all traffic is
# proxied to the Next.js frontend (which proxies /api/v1 to the backend internally). The
# cookie gate does not touch the Authorization header, so the app's own JWT bearer auth
# (GitHub login for chat/diff) works unchanged.

{
	email {$DEVLENS_TLS_EMAIL}
}

{$DEVLENS_DOMAIN} {
	encode zstd gzip
	root * /srv

	# Login submission: correct key sets the access cookie, wrong key returns to the page.
	@gate path /__gate
	handle @gate {
		@ok query key={$DEVLENS_GATE_SECRET}
		handle @ok {
			header Set-Cookie "devlens_access={$DEVLENS_GATE_SECRET}; Path=/; Max-Age=2592000; Secure; HttpOnly; SameSite=Lax"
			header Location "/"
			respond "" 302
		}
		handle {
			header Location "/?denied=1"
			respond "" 302
		}
	}

	# No valid access cookie: serve the branded gate page.
	@ungated not header Cookie *devlens_access={$DEVLENS_GATE_SECRET}*
	handle @ungated {
		rewrite * /gate.html
		file_server
	}

	# Gated in: proxy everything to the app (SSE-safe).
	handle {
		reverse_proxy frontend:3000 {
			flush_interval -1
		}
	}
}
